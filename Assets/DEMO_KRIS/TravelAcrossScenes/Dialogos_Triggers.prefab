    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: voices.Array.data[37]
      value: 
      objectReference: {fileID: 8300000, guid: be30adf8efed9d840a7f4723ca297d95, type: 3}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.size
      value: 39
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[0]
      value: "NOA\r\n(Mi cabeza... \xBFD\xF3nde estoy?)"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[1]
      value: 'NOA

        (Recuerdo... El submarino colapsar y... Aquella figura...
        Ojos amarillos...)'
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[2]
      value: "NOA\r\n(\xA1La sirena!\xA1La vi con mis propios ojos! Necesito averiguar
        d\xF3nde est\xE1.)"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[3]
      value: "DR. CORALIUS\r\n\xA1Diablos! \xBFQu\xE9 haces aqu\xED, jovenzuelo?
        \xBFQui\xE9n te env\xEDa? No ser\xE1s del banco, \xBFno?"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[4]
      value: "DR. CORALIUS\r\n\xBFY COMO EN NOMBRE DE EINSTEIN HAS ENTRADO AQU\xCD?"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[5]
      value: "MORTIMER (O.S.)\r\n\xBFCoraliuz, ezt\xE1 todo bien? He o\xEDdo gritoz"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[6]
      value: "MORTIMER\r\nOh... \xBFezte ez el...? \xBFNuevo buzo...?"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[7]
      value: "MORTIMER\r\nPenz\xE9 que no noz mandar\xEDan a nadie."
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[8]
      value: "DR. CORALIUS\r\n\xBFEh?"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[9]
      value: "NOA\r\n\xBFEh?"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: portraitsSprites.Array.size
      value: 39
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[10]
      value: 'DR. CORALIUS

        ...'
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[11]
      value: 'DR. CORALIUS

        ....'
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[12]
      value: 'DR. CORALIUS

        .....'
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[13]
      value: "DR. CORALIUS\r\n\xA1Claro! \xA1Eres t\xFA!"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[14]
      value: "DR. CORALIUS\r\nHe-he-he, \xBFd\xF3nde est\xE1n mis modales?"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[15]
      value: "DR. CORALIUS\r\nMi nombre es Coralius, \xA1Doctor Coralius! \xA1Que
        no se te olvide!"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[16]
      value: "DR. CORALIUS\r\nSoy uno de los bi\xF3logos a cargo del proyecto Aquamarina."
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[17]
      value: "DR. CORALIUS\r\n\xA1Una iniciativa ahora subvencionada por el gobierno
        para la investigaci\xF3n de seres marinos en las profundidades de estas fosas!"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[18]
      value: "DR. CORALIUS\r\nEste de aqu\xED es mi compa\xF1ero. \xA1Vamos! Ten
        algo de educaci\xF3n y pres\xE9ntate."
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[19]
      value: 'MORTIMER

        Yo... Yo soy Mortimer...'
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[20]
      value: "NOA\r\nEn-encantado (\xBF\xA1Eso es un pulpo!?)"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[21]
      value: 'NOA

        Yo soy Noa. Soy errn... Un buzo del... Programa gubernamental
        de Buzos... U-unidos.'
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[22]
      value: 'DR. CORALIUS

        ...'
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[23]
      value: "DR. CORALIUS\r\n\xBFEso existe?"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[24]
      value: 'NOA

        D-definitivamente.'
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[25]
      value: 'DR. CORALIUS

        ...'
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[26]
      value: "DR. CORALIUS\r\nWow, entonces tienes que ser toda un profesional. \xA1Qu\xE9
        privilegio!"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[27]
      value: "DR. CORALIUS\r\nEntonces supongo que ya te habr\xE1n puesto al tanto,
        pero necesitamos que investigues La Fosa de los Tritones y recopiles informaci\xF3n
        de la zona."
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[28]
      value: "DR. CORALIUS\r\nPor desgracia, hace unos d\xEDas se estroparon unos
        equipos y sufrimos una p\xE9rdida de datos..."
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[29]
      value: 'DR. CORALIUS

        Y con ellos nuestro registro de especies. Por
        ello te entrego esta PDA...'
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[30]
      value: "\r\u201C\xA1Has recibido una PDA!\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[31]
      value: "DR. CORALIUS\r\nCon ella registrar\xE1s la informaci\xF3n de cada especie
        que descubras."
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[32]
      value: "DR. CORALIUS\r\nLos datos se rellenar\xE1n autom\xE1ticamente cuando
        hagas una foto a una especie desconocida..."
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[33]
      value: "DR. CORALIUS\r\n\xA1Ah claro! Toma, que casi se me olvida he-he-he."
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[34]
      value: "\u201C\xA1Una c\xE1mara subacu\xE1tica!\u201D\n\n\u201CEst\xE1 algo
        h\xFAmeda...\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[35]
      value: "DR. CORALIUS\r\nBueno bueno, no te haremos perder m\xE1s el tiempo."
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[36]
      value: "DR. CORALIUS\r\nDurante la misi\xF3n nos conectaremos por un intercomunicador.
        \xA1Buena suerte!"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[37]
      value: "NOA\r\n\xA1G-gracias!"
      objectReference: {fileID: 0}
    - target: {fileID: 4322599027654860559, guid: d7b90f56c06c64841a671ae82410bce7, type: 3}
      propertyPath: dialogueLines.Array.data[38]
      value: "NOA\r\n(Esta podr\xEDa ser mi oportunidad para encontrar a la sirena...)"
      objectReference: {fileID: 0}
