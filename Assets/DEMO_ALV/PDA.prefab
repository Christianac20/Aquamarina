  m_text: "Pulpo, Octopus vulgaris\nMide entre 50 - 80 cm\nH\xE1bitat: Zona media\nEsperanza
    de  vida: 1 - 2 a\xF1os\nDieta: Can\xEDvora\nCar\xE1cter: Asustadizo\nEstado
    de conservaci\xF3n:\nNo amenazado\n\nDATO CURIOSO:\nPuede abrir frascos, usar
    herramientas y cambiar de color para camuflarse en segundos."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 355857c278d91254eaac9f84b5979225, type: 2}
